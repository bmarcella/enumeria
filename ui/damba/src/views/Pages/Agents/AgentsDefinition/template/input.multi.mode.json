{
  "type": "object",
  "required": ["mode"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["safe", "balanced", "aggressive"],
      "description": "Defines how invasive the agent can be."
    },
    "maxIterations": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 6
    },
    "allowedFilePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z0-9_./*-]+$"
      },
      "description": "Glob patterns the agent can modify."
    },
    "disallowedPaths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": ["node_modules", "dist", ".env"]
    }
  }
}